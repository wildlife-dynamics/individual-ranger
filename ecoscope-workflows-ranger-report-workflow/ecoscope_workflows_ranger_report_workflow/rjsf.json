    "Patrol and Event Types": {
      "type": "object",
      "description": "",
      "ecoscope:task_group": true,
      "properties": {
        "patrol_and_events_params": {
          "additionalProperties": false,
          "properties": {
            "status": {
              "default": [
                "done"
              ],
              "items": {
                "enum": [
                  "active",
                  "overdue",
                  "done",
                  "cancelled"
                ],
                "type": "string"
              },
              "title": "Patrol Status",
              "type": "array",
              "description": "Choose to analyze patrols with a certain status. If left empty, patrols of all status will be analyzed",
              "uniqueItems": true,
              "ecoscope:advanced": true
            },
            "patrols_overlap_daterange": {
              "default": true,
              "title": "Patrols Overlap Daterange",
              "type": "boolean",
              "description": "Whether or not to include patrols that start or end outside of the time range",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": ""
        }
      }
    },
    "": {
      "type": "object",
      "description": "",
      "ecoscope:task_group": true,
      "properties": {
        "patrol_trajectory": {
          "additionalProperties": false,
          "properties": {
            "trajectory_segment_filter": {
              "allOf": [
                {
                  "$ref": "#/$defs/TrajectorySegmentFilter"
                }
              ],
              "default": {
                "min_length_meters": 0.001,
                "max_length_meters": 100000,
                "min_time_secs": 1,
                "max_time_secs": 172800,
                "min_speed_kmhr": 0.01,
                "max_speed_kmhr": 500
              },
              "title": " ",
              "description": "Filter track data by setting limits on track segment length, duration, and speed. Segments outside these bounds are removed, reducing noise and to focus on meaningful movement patterns.",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Patrol Trajectory"
        }
      }
    },
    "Report Tables": {
      "type": "object",
