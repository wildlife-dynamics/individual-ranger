    "download_attachments": {
      "additionalProperties": false,
      "properties": {
        "attachments_subdir": {
          "default": "attachments",
          "title": "Attachments Subdirectory",
          "type": "string",
          "description": "Subdirectory inside the output directory to store attachments.",
          "ecoscope:advanced": true
        },
        "skip_download": {
          "default": false,
          "title": "Skip Download",
          "type": "boolean",
          "description": "If True, skip downloading attachments."
        }
      },
      "required": [],
      "type": "object",
      "title": "Download Attachments"
    },
    "generate_report": {
      "additionalProperties": false,
      "properties": {
        "include_attachment": {
          "default": false,
          "title": "Include Attachment",
          "type": "boolean",
          "description": "Whether to include the event attachment in the report."
        }
      },
      "required": [],
      "type": "object",
      "title": "Generate Ranger Report"
