    "Spatial Features": {
      "type": "object",
      "description": "Fetch spatial features from EarthRanger and render them as a map layer.",
      "ecoscope:task_group": true,
      "properties": {
        "spatial_features": {
          "additionalProperties": false,
          "properties": {
            "source": {
              "allOf": [
                {
                  "$ref": "#/$defs/EarthRangerSource"
                }
              ],
              "default": null,
              "title": "Source"
            },
            "group_by": {
              "default": "type_name",
              "title": "Group By",
              "type": "string",
              "description": "Column used to group features in the map legend e.g. 'Feature Type' shows one legend entry per feature type.",
              "oneOf": [
                {
                  "const": "type_name",
                  "title": "Feature Type"
                },
                {
                  "const": "title",
                  "title": "Feature Name"
                }
              ],
              "ecoscope:advanced": true
            },
            "legend_title": {
              "default": "",
              "title": "Legend Title",
              "type": "string",
              "description": "Label shown in the map legend e.g. 'Park Boundary'.",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": ""
        }
      }
    },
    "Local Spatial Features": {
      "type": "object",
      "description": "Load spatial features from a local file and render them as a map layer.",
      "ecoscope:task_group": true,
      "properties": {
        "local_spatial_file": {
          "additionalProperties": false,
          "properties": {
            "file_path": {
              "default": "",
              "title": "File Path",
              "type": "string",
              "description": "Path to the geospatial file. Supported formats: GeoJSON (.geojson), GeoPackage (.gpkg), and GeoParquet (.parquet / .geoparquet).",
              "ecoscope:advanced": true
            },
            "layer": {
              "default": null,
              "title": "Layer",
              "type": "string",
              "description": "Layer name within a GeoPackage file. Only required when the file contains multiple layers.",
              "ecoscope:advanced": true
            },
            "group_by": {
              "default": "",
              "title": "Group By",
              "type": "string",
              "description": "Column used to group features in the map legend e.g. 'name', 'category'.",
              "ecoscope:advanced": true
            },
            "legend_title": {
              "default": "",
              "title": "Legend Title",
              "type": "string",
              "description": "Label shown in the map legend e.g. 'Park Boundary'.",
              "ecoscope:advanced": true
            },
            "style": {
              "default": null,
              "items": {
                "$ref": "#/$defs/LayerStyle"
              },
              "maxLength": 1,
              "title": "Style",
              "type": "array",
              "description": "Optional: Customise how features are rendered on the map.",
              "ecoscope:advanced": true
            }
          },
          "type": "object",
          "required": [],
          "title": ""
        }
      }
    },
    "Patrol Maps": {
      "type": "object",
      "description": "Create maps for patrol trajectories and events.",
      "ecoscope:task_group": true,
      "properties": {
        "patrol_map_view_state": {
          "additionalProperties": false,
          "properties": {
            "max_zoom": {
              "default": 20,
              "title": "Max Zoom",
              "type": "number"
            }
          },
          "required": [],
          "type": "object",
          "title": "Patrol Tracks Map View State"
        },
        "event_map_view_state": {
          "additionalProperties": false,
          "properties": {
            "max_zoom": {
              "default": 20,
              "title": "Max Zoom",
              "type": "number"
            }
          },
          "required": [],
          "type": "object",
          "title": "Event Scatterplot Map View State"
        }
      }
