  "$defs": {
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "TrajectorySegmentFilter": {
      "properties": {
        "min_length_meters": {
          "default": 0.001,
          "ecoscope:advanced": true,
          "minimum": 0.001,
          "title": "Minimum Segment Length (Meters)",
          "type": "number"
        },
        "max_length_meters": {
          "default": 100000,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Length (Meters)",
          "type": "number"
        },
        "min_time_secs": {
          "default": 1,
          "ecoscope:advanced": true,
          "minimum": 1,
          "title": "Minimum Segment Duration (Seconds)",
          "type": "number"
        },
        "max_time_secs": {
          "default": 172800,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 1,
          "title": "Maximum Segment Duration (Seconds)",
          "type": "number"
        },
        "min_speed_kmhr": {
          "default": 0.01,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Minimum Segment Speed (Kilometers per Hour)",
          "type": "number"
        },
        "max_speed_kmhr": {
          "default": 500,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Speed (Kilometers per Hour)",
          "type": "number"
        }
      },
      "title": "TrajectorySegmentFilter",
      "type": "object"
    },
    "TableConfig": {
      "properties": {
        "enable_sorting": {
          "default": true,
          "title": "Enable Sorting",
          "type": "boolean"
        },
        "enable_filtering": {
          "default": false,
          "title": "Enable Filtering",
          "type": "boolean"
        },
        "enable_download": {
          "default": false,
          "title": "Enable Download",
          "type": "boolean"
        },
        "hide_header": {
          "default": false,
          "title": "Hide Header",
          "type": "boolean"
        }
      },
      "title": "TableConfig",
      "type": "object"
    },
    "EarthRangerSource": {
      "properties": {
        "query": {
          "anyOf": [
            {
              "$ref": "#/$defs/FeatureSetQuery"
            },
            {
              "$ref": "#/$defs/FeatureTypeQuery"
            },
            {
              "$ref": "#/$defs/FeatureIdQuery"
            }
          ],
          "default": null,
          "title": "Query"
        }
      },
      "title": "EarthRanger",
      "type": "object"
    },
    "FeatureIdQuery": {
      "description": "Load a single spatial feature by its EarthRanger UUID.",
      "properties": {
        "feature_id": {
          "description": "UUID of a specific spatial feature available on EarthRanger.",
          "title": "Feature Id",
          "type": "string"
        },
        "style": {
          "default": [],
          "description": "Optional: Override how EarthRanger spatial features are rendered on the map. If not specified, features will use their native EarthRanger colours and styling.",
          "items": {
            "$ref": "#/$defs/LayerStyle"
          },
          "maxItems": 1,
          "title": "Style",
          "type": "array"
        }
      },
      "required": [
        "feature_id"
      ],
      "title": "Feature ID",
      "type": "object"
    },
    "FeatureSetQuery": {
      "description": "Load all features from a named EarthRanger featureset.",
      "properties": {
        "featureset_name": {
          "description": "Display name of the featureset exactly as it appears in EarthRanger e.g. 'Boundaries'.",
          "minLength": 1,
          "title": "Featureset Name",
          "type": "string"
        }
      },
      "required": [
        "featureset_name"
      ],
      "title": "Feature Set",
      "type": "object"
    },
    "FeatureTypeQuery": {
      "description": "Load all features of a given type across EarthRanger featuresets.",
      "properties": {
        "feature_type": {
          "description": "Feature type name as shown in EarthRanger e.g. 'Conservancy'.",
          "minLength": 1,
          "title": "Feature Type",
          "type": "string"
        },
        "style": {
          "default": [],
          "description": "Optional: Override how EarthRanger spatial features are rendered on the map. If not specified, features will use their native EarthRanger colours and styling.",
          "items": {
            "$ref": "#/$defs/LayerStyle"
          },
          "maxItems": 1,
          "title": "Style",
          "type": "array"
        }
      },
      "required": [
        "feature_type"
      ],
      "title": "Feature Type",
      "type": "object"
    },
    "LayerStyle": {
      "properties": {
        "polygon": {
          "default": [],
          "description": "Polygon styling. Add one entry to override ER native colours.",
          "items": {
            "$ref": "#/$defs/PolygonStyle"
          },
          "maxItems": 1,
